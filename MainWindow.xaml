<Window x:Class="LocalContextBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalContextBuilder" Height="60" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" Focusable="False" IsHitTestVisible="False">
    <Border Background="#D9141414" CornerRadius="8" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="12,8" Margin="5"
            HorizontalAlignment="Left" VerticalAlignment="Top" x:Name="MainBorder" Visibility="Hidden">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="10" ShadowDepth="2" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="SuggestionText" Foreground="#E0E0E0" FontSize="16" FontFamily="Segoe UI" Text="suggestion..." VerticalAlignment="Center" />
            <Border Background="#26FFFFFF" CornerRadius="4" Padding="6,2" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Foreground="#B0B0B0" FontSize="11" FontWeight="SemiBold" Text="TAB TO ACCEPT" />
            </Border>
        </StackPanel>
    </Border>
</Window>
