<Window x:Class="LocalContextBuilder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Context Builder Settings" Height="400" Width="500"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="GGUF Model Path" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ModelPathBox" Background="#2D2D2D" Foreground="White" BorderBrush="#3D3D3D" Padding="5"/>
                <Button Grid.Column="1" Content="Browse" Click="Browse_Click" Margin="5,0,0,0" Padding="10,2" Background="#3D3D3D" Foreground="White"/>
            </Grid>

            <CheckBox x:Name="NpuCheckBox" Content="Use NPU (Intel AI Boost)" Margin="0,0,0,15" Foreground="White"/>

            <TextBlock Text="GPU Layers (Offload)" Margin="0,0,0,5"/>
            <TextBox x:Name="GpuLayersBox" Background="#2D2D2D" Foreground="White" BorderBrush="#3D3D3D" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Context Size" Margin="0,0,0,5"/>
            <TextBox x:Name="ContextSizeBox" Background="#2D2D2D" Foreground="White" BorderBrush="#3D3D3D" Padding="5" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save &amp; Restart Server" Click="Save_Click" Padding="20,10" Background="#007ACC" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="Cancel" Click="Cancel_Click" Padding="20,10" Background="#3D3D3D" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
